{
    "include": [
        "src/**/*"
    ],
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "rootDir": "./src/",
        "moduleResolution": "nodenext",
        "allowJs": true,
        "declaration": true,
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    }
}
